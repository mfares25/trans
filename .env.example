# Required
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# AI extraction/translation runs via the local Claude Code CLI (`claude -p`),
# using your logged-in Claude Code session — no ANTHROPIC_API_KEY needed.

# Optional — if omitted the app resolves it automatically from @FabrizioRomano on startup
FABRIZIO_ROMANO_USER_ID=

# Optional
PORT=3000
